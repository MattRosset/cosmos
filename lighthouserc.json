{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm exec serve apps/web/dist -l 42495",
      "startServerReadyPattern": "localhost:42495",
      "url": ["http://localhost:42495/index.html"],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "interactive": ["error", { "maxNumericValue": 4000 }]
      }
    }
  }
}
