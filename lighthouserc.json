{
  "ci": {
    "collect": {
      "staticDistDir": "apps/web/dist",
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "interactive": ["error", { "maxNumericValue": 4000 }]
      }
    }
  }
}
