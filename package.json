{
  "name": "cosmos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser-based real-time 3D universe explorer",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test --filter=!@cosmos/e2e",
    "test:e2e": "pnpm --filter @cosmos/web build && pnpm --filter @cosmos/e2e test:gate --project=chromium",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "check:bundle": "node tools/check-bundle-size/src/check.mjs",
    "lighthouse": "lhci autorun",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "pnpm": {
    "overrides": {
      "tslib": "^2.8.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "serve": "^14.0.0",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
